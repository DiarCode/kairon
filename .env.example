# Kairon Environment Configuration Example
# Copy this file to `.env` and replace the values with your own credentials.
# Never commit real API keys to version control.

# -----------------------------------------------------------------------------
# Bybit API credentials (testnet/demo)
# -----------------------------------------------------------------------------
KAIRON_BYBIT_API_KEY=your_api_key_here
KAIRON_BYBIT_API_SECRET=your_api_secret_here
KAIRON_BYBIT_TESTNET=true
KAIRON_BYBIT_TLD=kz

# Bybit broker transport: "pybit" (default, uses pybit SDK) or "raw"
# (direct httpx/websockets for transparent signing/request logging).
KAIRON_BYBIT_BROKER=pybit

# -----------------------------------------------------------------------------
# Live trading mode
# -----------------------------------------------------------------------------
# For testnet accounts created on testnet.bybit.kz, set KAIRON_BYBIT_TLD=kz.
# Other supported values: com, hk, eu, nl.
# Symbols default to BTC+ETH so the example matches test defaults.
# If you want SOL too, add it to the list.
# Dry-run uses PaperBroker (no real orders). Must be true when on testnet.
KAIRON_LIVE_DRY_RUN=true

# Symbols to trade in canonical Kairon format.
KAIRON_LIVE_SYMBOLS=["BTC-USDT-PERP","ETH-USDT-PERP"]

# Candle timeframe and tick cadence.
KAIRON_LIVE_TIMEFRAME=1m
KAIRON_LIVE_CADENCE_SECONDS=60

# -----------------------------------------------------------------------------
# Risk caps
# -----------------------------------------------------------------------------
KAIRON_LIVE_MAX_DAILY_LOSS_PCT=0.03
KAIRON_LIVE_MAX_OPEN_POSITIONS=5
KAIRON_LIVE_WARMUP_BARS=22

# -----------------------------------------------------------------------------
# Model boot
# -----------------------------------------------------------------------------
KAIRON_LIVE_MODEL_PATH=
KAIRON_LIVE_HORIZON=day

# -----------------------------------------------------------------------------
# Reconciliation
# -----------------------------------------------------------------------------
KAIRON_LIVE_RECONCILE_INTERVAL_SECONDS=30
KAIRON_LIVE_RECONCILE_GRACE_SECONDS=120

# -----------------------------------------------------------------------------
# Live promotion gate (manual ack required for --live)
# -----------------------------------------------------------------------------
# Set to 1 only after reviewing docs/live-promotion.md and signing the checklist.
KAIRON_LIVE_PROMOTION_ACK=0

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
KAIRON_LOG_LEVEL=INFO
KAIRON_LOG_FORMAT=json
